[Unit]
Description=TaleVision e-ink display daemon
After=network.target

[Service]
Type=simple
User=enuzzo
WorkingDirectory=/home/enuzzo/talevision
ExecStart=/home/enuzzo/talevision/venv/bin/python main.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

Environment=PYTHONUNBUFFERED=1
Environment=PYTHONDONTWRITEBYTECODE=1

[Install]
WantedBy=multi-user.target
