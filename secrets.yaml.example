# Copy to secrets.yaml and fill in values. Never commit secrets.yaml.
# Generate bcrypt hash: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
web_auth:
  username: "admin"
  password_hash: "<BCRYPT_HASH>"
webhook_url: null
weather_api_key: null
# Groq API key for Koan mode haiku generation (free at console.groq.com)
groq_api_key: "<GROQ_API_KEY>"
